# =============================================================================
# Eagles & Eaglets — Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
# For Railway: set these in the Railway dashboard → Service → Variables.
# =============================================================================

# =============================================================================
# CORE DJANGO
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=your-50-char-secret-key-here

# Django settings module — use production for Railway deployment
DJANGO_SETTINGS_MODULE=eaglesneagletsbackend.settings.production

# Comma-separated list of allowed hostnames (no http://)
# Railway auto-provides: healthcheck.railway.app and .up.railway.app
# Add your custom domain here if you have one
ALLOWED_HOSTS=your-backend-name.up.railway.app,yourdomain.com

# =============================================================================
# DATABASE (Railway injects DATABASE_URL automatically for Postgres service)
# =============================================================================
# Railway provides this automatically — copy from Postgres service → Connect tab
DATABASE_URL=postgresql://postgres:password@host.railway.internal:5432/railway

# =============================================================================
# REDIS (Railway injects REDIS_URL automatically for Redis service)
# =============================================================================
# Railway provides this automatically — copy from Redis service → Connect tab
REDIS_URL=redis://default:password@host.railway.internal:6379

# =============================================================================
# CORS & CSRF (your Railway frontend URL)
# =============================================================================
# Comma-separated list of trusted origins (include https://)
CORS_ALLOWED_ORIGINS=https://your-frontend-name.up.railway.app,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://your-backend-name.up.railway.app,https://yourdomain.com

# =============================================================================
# FRONTEND URL (used in email verification links, payment callbacks)
# =============================================================================
FRONTEND_URL=https://your-frontend-name.up.railway.app

# =============================================================================
# PAYMENT — Paystack
# Get from: https://dashboard.paystack.com/#/settings/developer
# =============================================================================
# Use sk_test_... for staging, sk_live_... for production
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# =============================================================================
# MEDIA STORAGE — Cloudinary (primary) or AWS S3 (alternative)
# Get from: https://cloudinary.com/console
# =============================================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key-number
CLOUDINARY_API_SECRET=your-api-secret-here

# Leave blank to use Cloudinary instead of S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# =============================================================================
# EMAIL — SMTP (Gmail example; use App Password, not your account password)
# For Gmail App Password: https://myaccount.google.com/apppasswords
# =============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SERVER_EMAIL=errors@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# =============================================================================
# ERROR MONITORING — Sentry (optional but strongly recommended for production)
# Get from: https://sentry.io → New Project → Django
# =============================================================================
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/your-project-id

# =============================================================================
# GOOGLE OAUTH2 (optional — only if Google login is enabled)
# Get from: https://console.cloud.google.com → Credentials
# =============================================================================
GOOGLE_OAUTH2_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH2_CLIENT_SECRET=your-client-secret-here
GOOGLE_OAUTH2_REDIRECT_URI=https://your-backend-name.up.railway.app/api/v1/auth/google/callback/

# =============================================================================
# HEALTH CHECK
# =============================================================================
# Optional token to protect the health endpoint from public scraping
HEALTH_CHECK_TOKEN=your-random-token-here
